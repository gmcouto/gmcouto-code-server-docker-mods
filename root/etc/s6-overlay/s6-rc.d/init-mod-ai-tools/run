#!/usr/bin/with-contenv bash

echo "**** installing AI CLI tools ****"

# Note: screen, tmux, fd-find, ripgrep and fzf are registered for batch installation by
# init-mod-ai-tools-packages and installed by init-mods-package-install.
# This service runs after init-mods-package-install, so they are available.

# ---------------------------------------------------------------------------
# Locate npm via NVM
# This service depends on init-mod-code-server-nvm-install, so NVM and its
# default node (which bundles npm) are guaranteed to be ready by now.
# ---------------------------------------------------------------------------
# shellcheck source=/dev/null
source "${HOME}/.nvm/nvm.sh"

if command -v npm &>/dev/null; then
    NPM_BIN="npm"
else
    echo "**** npm not found – is linuxserver/mods:code-server-nvm loaded? ****"
    NPM_BIN=""
fi

if [ -z "${NPM_BIN}" ]; then
    echo "**** skipping npm-based installations ****"
else
    # -----------------------------------------------------------------------
    # gemini-cli  (https://github.com/google-gemini/gemini-cli)
    # -----------------------------------------------------------------------
    echo "**** installing / updating gemini-cli ****"
    ${NPM_BIN} install -g @google/gemini-cli

    # -----------------------------------------------------------------------
    # claude-code  (https://github.com/anthropics/claude-code)
    # -----------------------------------------------------------------------
    echo "**** installing / updating claude-code ****"
    ${NPM_BIN} install -g @anthropic-ai/claude-code

    # -----------------------------------------------------------------------
    # openclaude  (https://github.com/Gitlawb/openclaude)
    # -----------------------------------------------------------------------
    echo "**** installing / updating openclaude ****"
    ${NPM_BIN} install -g @gitlawb/openclaude

    # -----------------------------------------------------------------------
    # github-copilot-cli  (https://github.com/github/copilot-cli)
    # -----------------------------------------------------------------------
    echo "**** installing / updating github copilot CLI ****"
    ${NPM_BIN} install -g @github/copilot

    # -----------------------------------------------------------------------
    # codex CLI  (https://github.com/openai/codex)
    # -----------------------------------------------------------------------
    echo "**** installing / updating openai codex CLI ****"
    ${NPM_BIN} install -g @openai/codex
fi

# ---------------------------------------------------------------------------
# cursor CLI  (https://cursor.com/docs/cli/installation)
# The installer places cursor-agent (and a cursor wrapper) in ~/.local/bin/
# ---------------------------------------------------------------------------
if command -v cursor-agent &>/dev/null; then
    echo "**** cursor-agent CLI already installed, skipping ****"
else
    echo "**** installing cursor CLI ****"
    CURSOR_INSTALL_SCRIPT="$(mktemp /tmp/cursor-install-XXXXXX.sh)"
    if curl -fsSL -o "${CURSOR_INSTALL_SCRIPT}" https://cursor.com/install; then
        bash "${CURSOR_INSTALL_SCRIPT}"
        rm -f "${CURSOR_INSTALL_SCRIPT}"
        # The installer places binaries under ~/.local/bin; symlink both into PATH
        CURSOR_LOCAL_BIN="${HOME}/.local/bin"
        for binary in cursor-agent cursor; do
            if [ -f "${CURSOR_LOCAL_BIN}/${binary}" ]; then
                if ln -sf "${CURSOR_LOCAL_BIN}/${binary}" "/usr/local/bin/${binary}"; then
                    echo "**** ${binary} symlinked to /usr/local/bin/${binary} ****"
                else
                    echo "**** warning: could not create /usr/local/bin/${binary} symlink ****"
                    echo "**** ${binary} binary is available at ${CURSOR_LOCAL_BIN}/${binary} ****"
                fi
            fi
        done
    else
        rm -f "${CURSOR_INSTALL_SCRIPT}"
        echo "**** cursor CLI installation failed – skipping ****"
    fi
fi

echo "**** AI CLI tools installation complete ****"
